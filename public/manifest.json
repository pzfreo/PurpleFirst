{
  "name": "Purple First",
  "short_name": "PurpleFirst",
  "start_url": "/PurpleFirst/",
  "display": "standalone",
  "background_color": "#1a1a1a",
  "theme_color": "#7B2D8B",
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "/PurpleFirst/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "image",
          "accept": ["image/png", "image/jpeg", "image/webp", ".png", ".jpg", ".jpeg", ".webp"]
        }
      ]
    }
  }
}
